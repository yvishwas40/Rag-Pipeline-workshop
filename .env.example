# Copy this file to ".env" and fill in your real keys (never commit .env).

# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Pinecone console: https://app.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here

# Name of the Pinecone index (we will create it if it does not exist)
PINECONE_INDEX_NAME=rag-workshop-demo

# For Pinecone Serverless indexes, "environment" is replaced by cloud + region.
# Common defaults for teaching: AWS + us-east-1
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Optional Gemini model ids (google-genai)
# GEMINI_CHAT_MODEL=gemini-1.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_DIMENSION=768
